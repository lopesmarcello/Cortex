{
    "name": "syntra",
    "version": "0.1.4",
    "description": "CLI tool that scaffolds, manages, and syncs an AI-assisted development framework across projects and AI tools",
    "type": "module",
    "main": "dist/index.js",
    "bin": {
        "syntra": "dist/index.js"
    },
    "scripts": {
        "dev": "tsx src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint src --ext .ts"
    },
    "keywords": [
        "ai",
        "framework",
        "cli",
        "scaffolding",
        "copilot",
        "claude",
        "cursor"
    ],
    "author": "xelo",
    "license": "MIT",
    "dependencies": {
        "commander": "^11.1.0",
        "inquirer": "^8.2.5",
        "handlebars": "^4.7.7",
        "yaml": "^2.3.4",
        "chalk": "^5.3.0",
        "ora": "^8.0.1",
        "fast-glob": "^3.3.2",
        "ajv": "^8.12.0"
    },
    "devDependencies": {
        "@types/node": "^20.10.5",
        "@types/inquirer": "^8.2.6",
        "typescript": "^5.3.3",
        "tsx": "^4.7.0",
        "vitest": "^1.0.4",
        "eslint": "^8.56.0",
        "@typescript-eslint/eslint-plugin": "^6.15.0",
        "@typescript-eslint/parser": "^6.15.0"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}